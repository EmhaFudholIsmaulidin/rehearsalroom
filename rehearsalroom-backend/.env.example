# Database — default SQLite (tidak butuh server, cukup file lokal)
DATABASE_URL=sqlite:///./rehearsalroom.db

# Ganti dengan string acak yang kuat untuk produksi
SECRET_KEY=ubah-secret-key-ini-untuk-produksi
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
FRONTEND_URL=http://localhost:5173

# --- OPSIONAL: pakai PostgreSQL untuk nilai lebih ---
# DATABASE_URL=postgresql://postgres:password@localhost:5432/rehearsalroom
# (lalu jalankan: alembic upgrade head)

# --- OPSIONAL: kirim email undangan via SMTP ---
